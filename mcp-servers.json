{
  "servers": [
    {
      "name": "obsidian",
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-server-obsidian"],
      "env": {
        "OBSIDIAN_VAULT_PATH": "/path/to/vault"
      }
    },
    {
      "name": "filesystem",
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-server-filesystem", "/path/to/project"],
      "env": {}
    }
  ]
}
