{
  "name": "@milo/agents",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./breadcrumbs": {
      "import": "./src/breadcrumbs.ts",
      "types": "./src/breadcrumbs.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "simulate": "tsx src/simulation.ts"
  },
  "dependencies": {
    "@milo/ai": "workspace:*",
    "@milo/database": "workspace:*",
    "@milo/shared": "workspace:*",
    "@milo/tools": "workspace:*",
    "bullmq": "^5.12.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}