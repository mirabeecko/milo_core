# MiLO_Core – Environment Variables
# Zkopíruj tento soubor jako .env a doplň skutečné hodnoty.

# ───────────────────────────────────────────────
# Supabase
# ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ───────────────────────────────────────────────
# Frontend
# ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ───────────────────────────────────────────────
# Backend
# ───────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=change-this-to-a-secure-random-string

# ───────────────────────────────────────────────
# AI Providers
# ───────────────────────────────────────────────
# OpenAI kompatibilní API
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama (volitelné, pro lokální modely)
OLLAMA_BASE_URL=http://localhost:11434

# ───────────────────────────────────────────────
# Google OAuth (Gmail, Calendar, Drive)
# ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# ───────────────────────────────────────────────
# Obsidian
# ───────────────────────────────────────────────
# Cesta k lokálnímu Obsidian vault v kontejneru / vývojovém prostředí
OBSIDIAN_VAULT_PATH=/data/obsidian-vault

# ───────────────────────────────────────────────
# MiLO Project Paths
# ───────────────────────────────────────────────
# Cesta ke kořenovému adresáři MiLO_Core (výchozí: /Users/mb/dev/MiLO_Core)
# MILO_PROJECT_PATH=/Users/mb/dev/MiLO_Core
# Kořenový adresář pro skenování projektů (výchozí: /Users/mb/dev)
# MILO_DEV_ROOT=/Users/mb/dev

# ───────────────────────────────────────────────
# Database (pouze pro lokální Docker Postgres)
# ───────────────────────────────────────────────
POSTGRES_USER=milo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=milo_core
DATABASE_URL=postgresql://milo:change-me@postgres:5432/milo_core