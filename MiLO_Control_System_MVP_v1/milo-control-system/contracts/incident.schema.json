{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milo.local/schemas/incident.schema.json",
  "title": "MiLO Incident Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["incident_id", "detected_at", "severity", "summary", "manifestation", "impact", "task_id", "run_id", "owner_agent_id", "status", "raw_log_refs", "created_at", "updated_at"],
  "properties": {
    "incident_id": {"type": "string", "pattern": "^INC-[A-Z0-9-]+$"},
    "detected_at": {"type": "string", "format": "date-time"},
    "severity": {"enum": ["P0", "P1", "P2", "P3"]},
    "summary": {"type": "string", "minLength": 1},
    "manifestation": {"type": "string", "minLength": 1},
    "impact": {"type": "string", "minLength": 1},
    "violated_requirement_ids": {"type": "array", "items": {"type": "string"}},
    "task_id": {"type": "string"},
    "run_id": {"type": "string"},
    "agent_id": {"type": ["string", "null"]},
    "owner_agent_id": {"type": "string"},
    "status": {"enum": ["OPEN", "INVESTIGATING", "MITIGATED", "DEFERRED", "RESOLVED", "ARCHIVED"]},
    "suspected_root_cause": {"type": ["string", "null"]},
    "immediate_mitigation": {"type": ["string", "null"]},
    "remediation_task_id": {"type": ["string", "null"]},
    "regression_test_ref": {"type": ["string", "null"]},
    "remind_at": {"type": ["string", "null"], "format": "date-time"},
    "raw_log_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "resolution_evidence_refs": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}

