{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://milo.local/schemas/task.schema.json",
  "title": "MiLO Task Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "command_id",
    "project_id",
    "requested_at",
    "requested_by",
    "original_request",
    "goal",
    "requirements",
    "acceptance_criteria",
    "risk",
    "status",
    "executor_agent_id",
    "reviewer_agent_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "task_id": {"type": "string", "pattern": "^TASK-[A-Z0-9-]+$"},
    "command_id": {"type": "string", "pattern": "^CMD-[A-Z0-9-]+$"},
    "project_id": {"type": "string", "minLength": 1},
    "goal_id": {"type": ["string", "null"]},
    "parent_task_id": {"type": ["string", "null"]},
    "requested_at": {"type": "string", "format": "date-time"},
    "requested_by": {"type": "string", "minLength": 1},
    "request_channel": {"type": "string"},
    "original_request": {"type": "string", "minLength": 1},
    "goal": {"type": "string", "minLength": 1},
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_id", "text", "status"],
        "properties": {
          "requirement_id": {"type": "string", "pattern": "^REQ-[0-9]+$"},
          "text": {"type": "string", "minLength": 1},
          "status": {"enum": ["OPEN", "MET", "NOT_MET", "WAIVED"]},
          "evidence_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "risk": {"enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "communication_profile": {"type": ["string", "null"]},
    "status": {"enum": ["INBOX", "TRIAGE", "READY", "IN_PROGRESS", "WAITING_EXTERNAL", "NEEDS_OWNER", "BLOCKED", "REVIEW", "DONE", "FAILED", "CANCELLED"]},
    "executor_agent_id": {"type": "string", "minLength": 1},
    "reviewer_agent_id": {"type": "string", "minLength": 1},
    "due_at": {"type": ["string", "null"], "format": "date-time"},
    "started_at": {"type": ["string", "null"], "format": "date-time"},
    "completed_at": {"type": ["string", "null"], "format": "date-time"},
    "last_event_at": {"type": ["string", "null"], "format": "date-time"},
    "blocked_reason": {"type": ["string", "null"]},
    "output_refs": {"type": "array", "items": {"type": "string"}},
    "review_id": {"type": ["string", "null"]},
    "owner_approval_id": {"type": ["string", "null"]},
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "amount": {"type": "number", "minimum": 0},
        "currency": {"type": "string", "minLength": 3, "maxLength": 3},
        "observed_at": {"type": "string", "format": "date-time"}
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  },
  "$comment": "Service-level constraints: executor_agent_id MUST differ from reviewer_agent_id; DONE requires all requirements MET or explicitly WAIVED, non-empty output_refs, review_id, completed_at, and owner_approval_id when the risk/profile requires it."
}

